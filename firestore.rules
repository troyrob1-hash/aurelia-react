rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function tenantId() {
      return request.auth.token["custom:tenantId"];
    }

    function role() {
      return request.auth.token["custom:role"];
    }

    function isAdmin()    { return role() == 'admin'    || role() == 'Admin'; }
    function isDirector() { return role() == 'director' || role() == 'Director' || isAdmin(); }
    function isManager()  { return role() == 'manager'  || role() == 'Manager'  || isDirector(); }

    function ownsTenant(tid) {
      return isAuth() && tenantId() == tid;
    }

    // ============================================================
    // aurelia/ — global config catalog (read-only from clients)
    // ============================================================
    match /aurelia/{doc} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ============================================================
    // tenants/{tenantId}/... — application data
    // ============================================================
    match /tenants/{tenantId} {
      allow read:  if ownsTenant(tenantId);
      allow write: if ownsTenant(tenantId) && isAdmin();

      match /config/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isDirector();
      }

      // Regions — named buckets of locations for director/manager access control.
      // Readable by anyone in the tenant (needed for visibility resolution).
      // Writable only by admins (creates, renames, add/remove locations).
      match /regions/{regionId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      match /settings/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isDirector();
      }

      match /inventory/{locationId}/items/{itemId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /inventorySessions/{sessionId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /pnl/{locationId}/periods/{periodId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /budgets/{budgetId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /budgetUnlockRequests/{reqId} {
        allow read:  if ownsTenant(tenantId) && isDirector();
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      match /invoices/{invoiceId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      // NEW: orders rule (was missing)
      match /orders/{orderId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /transfers/{transferId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && (
          isDirector() ||
          (isManager() && request.resource.data.status == 'Received')
        );
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /laborSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      match /salesSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      match /wasteSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      // Vendors and products — managers can create/update, directors can delete
      match /vendors/{vendorId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /products/{productId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /locations/{locationId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();

        match /inventory/{periodId} {
          allow read:  if ownsTenant(tenantId);
          allow write: if ownsTenant(tenantId) && isManager();
        }

        match /sales/{weekId} {
          allow read:  if ownsTenant(tenantId);
          allow write: if ownsTenant(tenantId) && isManager();
        }

        match /waste/{entryId} {
          allow read:  if ownsTenant(tenantId);
          allow create: if ownsTenant(tenantId) && isManager();
          allow delete: if ownsTenant(tenantId) && isManager();
        }
      }

      match /legacy/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      match /auditLog/{logId} {
        allow read:  if ownsTenant(tenantId) && isDirector();
        allow write: if false;
      }

      match /users/{userId} {
        allow read:  if ownsTenant(tenantId) && isManager();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      // NEW: access requests — admins read in Settings, never written from client
      // (submitAccessRequest Cloud Function uses admin SDK and bypasses rules)
      match /accessRequests/{requestId} {
        allow read:  if ownsTenant(tenantId) && isAdmin();
        allow write: if false;
      }
    }

    // ============================================================
    // NEW: orgs/{orgId}/... — admin and settings data
    // (Settings UI reads/writes here. Cloud Functions also write here
    // via admin SDK which bypasses rules.)
    // ============================================================
    match /orgs/{orgId} {
      allow read:  if ownsTenant(orgId);
      allow write: if ownsTenant(orgId) && isAdmin();

      match /users/{uid} {
        allow read:  if ownsTenant(orgId) && isManager();
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      match /userLocations/{joinId} {
        allow read:  if ownsTenant(orgId) && isManager();
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      match /locations/{locationId} {
        allow read:  if ownsTenant(orgId);
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      match /apiKeys/{keyId} {
        allow read:  if ownsTenant(orgId) && isAdmin();
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      match /auditLog/{logId} {
        allow read:  if ownsTenant(orgId) && isDirector();
        allow write: if false;
      }

      match /sessions/{sessionId} {
        allow read:  if ownsTenant(orgId);
        allow write: if false;
      }
    }

    // ============================================================
    // DEFAULT DENY — anything not matched above is rejected
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}