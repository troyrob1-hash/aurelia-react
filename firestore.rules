rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function tenantId() {
      return request.auth.token["custom:tenantId"];
    }

    function role() {
      return request.auth.token["custom:role"];
    }

    function isAdmin()    { return role() == 'admin'    || role() == 'Admin'; }
    function isDirector() { return role() == 'director' || role() == 'Director' || isAdmin(); }
    function isManager()  { return role() == 'manager'  || role() == 'Manager'  || isDirector(); }
    // VP is a peer of director (sees all, can't administer) but is NOT in the
    // isManager chain. Standalone helper so callers can opt VPs in explicitly.
    function isVp()       { return role() == 'vp'       || role() == 'VP'       || role() == 'Vp'; }

    function ownsTenant(tid) {
      return isAuth() && tenantId() == tid;
    }

    // ============================================================
    // aurelia/ — global config catalog (read-only from clients)
    // ============================================================
    match /aurelia/{doc} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ============================================================
    // tenants/{tenantId}/... — application data
    // ============================================================
    match /tenants/{tenantId} {
      allow read:  if ownsTenant(tenantId);
      allow write: if ownsTenant(tenantId) && isAdmin();

      match /config/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isDirector();
      }

      // Regions — named buckets of locations for director/manager access control.
      // Readable by anyone in the tenant (needed for visibility resolution).
      // Writable only by admins (creates, renames, add/remove locations).
      match /regions/{regionId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      match /settings/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isDirector();
      }

      // GL code catalog (VF #4) at settings/glCodes — the item-entry dropdowns
      // read it tenant-wide. The general settings/{doc} rule above already grants
      // read + director/admin write; this specialization ADDS vp to the write
      // tier (Firestore OR-evaluates matching rules), so GL-code curation is
      // director/vp/admin — same money-authority tier as period unlock.
      match /settings/glCodes {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && (isDirector() || isVp());
      }

      match /inventory/{locationId}/items/{itemId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      // Per-location inventory settings (e.g. the `categories` doc) — any real
      // operator role manages their own location's category groupings:
      // manager/director/vp/admin (everyone except plain viewers).
      match /inventory/{locationId}/settings/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && (isManager() || isVp());
      }

      // Per-week inventory counts (qty/eaches keyed by periodKey).
      match /inventory/{locationId}/counts/{periodKey} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      // Per-ITEM count docs (concurrency-safe re-architecture). Two counters on
      // two devices write different item docs — structurally clobber-proof.
      // Rules don't cascade to subcollections, so this needs its own match.
      match /inventory/{locationId}/counts/{periodKey}/items/{itemId} {
        allow read:  if ownsTenant(tenantId);
        // Server-side lock gate (belt-and-suspenders on the client-side check in
        // useInventory). Reject writes to a closed period. The lock doc id is
        // locId(location) + '__' + period == locationId + '__' + periodKey here.
        // Missing lock doc (the common case — most periods never locked) short-
        // circuits on exists() so get() is never evaluated -> no read, no 403.
        allow write: if ownsTenant(tenantId) && isManager()
          && (
            !exists(/databases/$(database)/documents/tenants/$(tenantId)/periodLocks/$(locationId + '__' + periodKey))
            || get(/databases/$(database)/documents/tenants/$(tenantId)/periodLocks/$(locationId + '__' + periodKey)).data.locked != true
          );
      }

      match /inventorySessions/{sessionId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      // Per-tenant master inventory catalog — migrated from the legacy
      // global aurelia/inv_items doc on Apr 12 2026. Each item is its own doc.
      // Read by anyone in the tenant; only directors can modify the master
      // catalog (managers can override per-location via the inventory rules above).
      match /inventoryCatalog/{itemId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isDirector();
      }

      // Per-user cart drafts for OrderHub cross-device sync. Doc ID format
      // is '{userId}__{locationId}'. Users can read/write only their own drafts.
      match /orderDrafts/{draftId} {
        allow read:  if ownsTenant(tenantId)
                     && draftId.matches('^' + request.auth.uid + '__.*');
        allow write: if ownsTenant(tenantId)
                     && draftId.matches('^' + request.auth.uid + '__.*')
                     && (request.resource.data.userId == null
                         || request.resource.data.userId == request.auth.uid);
      }

      // Credit memos generated from receiving discrepancies. Anyone in the
      // tenant can read (for AP review), managers+ can write (to create/
      // approve them on behalf of the tenant).
      match /creditMemos/{memoId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /pnl/{locationId}/periods/{periodId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /budgets/{budgetId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /budgetUnlockRequests/{reqId} {
        allow read:  if ownsTenant(tenantId) && isDirector();
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      match /invoices/{invoiceId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      // NEW: orders rule (was missing)
      match /orders/{orderId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /transfers/{transferId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && (
          isDirector() ||
          (isManager() && request.resource.data.status == 'Received')
        );
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /laborSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      match /salesSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
      }

      match /wasteSubmissions/{subId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
      }

      // Waste log entries (WasteLog.jsx writes per-item shrinkage events here,
      // keyed by location + periodKey). Delete restricted to director+ so
      // managers can log but can't quietly drop history.
      match /wasteLog/{entryId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      // POS imports keyed by {locationId}_{periodKey}. Same tier as inventory
      // counts — managers upload, anyone in tenant reads.
      match /posData/{docId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      // Vendors and products — managers can create/update, directors can delete
      match /vendors/{vendorId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /products/{productId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /locations/{locationId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();

        match /inventory/{periodId} {
          allow read:  if ownsTenant(tenantId);
          allow write: if ownsTenant(tenantId) && isManager();
        }

        match /sales/{weekId} {
          allow read:  if ownsTenant(tenantId);
          allow write: if ownsTenant(tenantId) && isManager();
        }

        match /waste/{entryId} {
          allow read:  if ownsTenant(tenantId);
          allow create: if ownsTenant(tenantId) && isManager();
          allow delete: if ownsTenant(tenantId) && isManager();
        }
      }

      // Journal entries + templates (Operating Ledger)
      match /journalEntries/{entryId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      match /jeTemplates/{templateId} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isDirector();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      // Period close status docs
      match /apClose/{closeId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /laborClose/{closeId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /salesClose/{closeId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /wasteClose/{closeId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /inventoryClose/{closeId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isManager();
      }

      match /legacy/{doc} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      match /auditLog/{logId} {
        allow read:  if ownsTenant(tenantId) && isDirector();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      match /users/{userId} {
        allow read:  if ownsTenant(tenantId) && isManager();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      // NEW: access requests — admins read in Settings, never written from client
      // (submitAccessRequest Cloud Function uses admin SDK and bypasses rules)
      match /accessRequests/{requestId} {
        allow read:  if ownsTenant(tenantId) && isAdmin();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      // In-app notifications. submitAccessRequest mirrors access-request alerts
      // here so admins can see them in the top-bar bell. Admin-only at the
      // rule layer because today's only writer (Cloud Function via admin SDK)
      // produces admin-only content. If manager-targeted notifications are
      // added later, add an `audience` field and broaden read accordingly.
      match /notifications/{notifId} {
        allow read:  if ownsTenant(tenantId) && isAdmin();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      // Period locks — the gate that prevents writes to a closed period.
      // pnl.js writePnL preflights read this; the close/reopen UIs call
      // lockPeriod / unlockPeriod to write. Gate by the DIRECTION being written,
      // not by who last touched the doc — so a manager can re-lock after a
      // director's reopen:
      //   • writing locked:true  (LOCK / re-lock) → any counter (mgr/dir/vp/admin)
      //   • writing locked:false (UNLOCK)         → override authority (dir/vp/admin)
      match /periodLocks/{periodKey} {
        allow read:   if ownsTenant(tenantId);
        allow create: if ownsTenant(tenantId) && (isManager() || isVp());
        allow update: if ownsTenant(tenantId) && (
          (request.resource.data.locked == true  && (isManager() || isVp()))
          || (request.resource.data.locked == false && (isDirector() || isVp()))
        );
        allow delete: if ownsTenant(tenantId) && (isDirector() || isVp());
      }

      // Valuation authority per location (Phase-2 cutover kill switch). Doc id is
      // the sanitized locId; { authoritative: 'cf' | 'client', ... }. The client's
      // saveCounts/save READ this on EVERY save (as whatever user is saving —
      // managers included) to decide who writes the live P&L, so read must be
      // tenant-wide: a director-gated read would make every manager save hit the
      // fail-safe and warn forever. WRITE flips the money-writer for a location —
      // an authority action, same tier as period unlock: director/vp/admin only
      // (isDirector() already includes isAdmin()).
      match /valuationMode/{locId} {
        allow read:  if ownsTenant(tenantId);
        allow write: if ownsTenant(tenantId) && (isDirector() || isVp());
      }

      // Client-side audit trail (src/lib/audit.js). Many manager-tier actions
      // append entries — invoice approve, JE post, sales import, period close,
      // etc. Read by Settings → Audit Log (admin-gated route). Append-only.
      match /auditTrail/{logId} {
        allow read:   if ownsTenant(tenantId) && isDirector();
        allow create: if ownsTenant(tenantId) && isManager();
        allow update, delete: if false;
      }

      // Vendor purchase orders. Currently written by processVendorInvoice
      // (integration ingestion) and Cloud Functions; mirrors the /orders rule
      // shape so future direct OrderHub PO writes need no rules deploy.
      match /purchaseOrders/{poId} {
        allow read:   if ownsTenant(tenantId) && isManager();
        allow create: if ownsTenant(tenantId) && isManager();
        allow update: if ownsTenant(tenantId) && isManager();
        allow delete: if ownsTenant(tenantId) && isDirector();
      }

      // POS transactions ingested from upstream POS systems. ONLY the Cloud
      // Function writes (admin SDK bypasses rules); client writes denied.
      // Manager-tier read leaves room for future revenue dashboards.
      match /posTransactions/{txnId} {
        allow read:  if ownsTenant(tenantId) && isManager();
        allow write: if false;
      }

      // Per-integration runtime status (Ramp, NetSuite, etc.) — credentials
      // live in Secret Manager, this is metadata/last-sync state. Setup and
      // read in Settings → Integration Map / Sync Status (admin-gated).
      match /integrations/{integId} {
        allow read:  if ownsTenant(tenantId) && isAdmin();
        allow write: if ownsTenant(tenantId) && isAdmin();
      }

      // Integration sync attempt log. Same admin-tier readers/writers as
      // /integrations. Append-only.
      match /syncLog/{logId} {
        allow read:   if ownsTenant(tenantId) && isAdmin();
        allow create: if ownsTenant(tenantId) && isAdmin();
        allow update, delete: if false;
      }
    }

    // ============================================================
    // NEW: orgs/{orgId}/... — admin and settings data
    // (Settings UI reads/writes here. Cloud Functions also write here
    // via admin SDK which bypasses rules.)
    // ============================================================
    match /orgs/{orgId} {
      allow read:  if ownsTenant(orgId);
      allow write: if ownsTenant(orgId) && isManager();

      match /users/{uid} {
        // Admins manage all users; every user may read/update only their OWN
        // doc (loadProfile reads roles/regions and writes lastLoginAt on login).
        // Closes the roster-enumeration leak: managers can no longer read the
        // full user list over the network.
        allow read:  if ownsTenant(orgId) && (isAdmin() || uid == request.auth.uid);
        allow write: if ownsTenant(orgId) && (isAdmin() || uid == request.auth.uid);
      }

      match /userLocations/{joinId} {
        allow read:  if ownsTenant(orgId) && isManager();
        allow write: if ownsTenant(orgId) && isManager();
      }

      match /locations/{locationId} {
        allow read:  if ownsTenant(orgId);
        allow write: if ownsTenant(orgId) && isManager();
      }

      match /apiKeys/{keyId} {
        allow read:  if ownsTenant(orgId) && isAdmin();
        allow write: if ownsTenant(orgId) && isManager();
      }

      match /auditLog/{logId} {
        allow read:  if ownsTenant(orgId) && isDirector();
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      match /sessions/{sessionId} {
        allow read:  if ownsTenant(orgId);
        allow write: if ownsTenant(orgId) && isAdmin();
      }

      // Ramp sync audit trail
      // Waste log entries
      match /wasteLog/{entryId} {
        allow read:  if ownsTenant(orgId);
        allow write: if ownsTenant(orgId) && isManager();
      }

      match /rampSync/{syncId} {
        allow read:  if ownsTenant(orgId);
        allow write: if ownsTenant(orgId) && isManager();
      }


    }

    // ============================================================
    // DEFAULT DENY — anything not matched above is rejected.
    //
    // NOTE: earlier versions of this block held nested rules for
    // periodLocks, auditTrail, syncLog, integrations, purchaseOrders,
    // posTransactions, and notifications that granted access on
    // `request.auth != null` only (no ownsTenant, no role check) — a P0
    // cross-tenant leak. All seven collections now live under
    // match /tenants/{tenantId} above with ownsTenant + role gating.
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
